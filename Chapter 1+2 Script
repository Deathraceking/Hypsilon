function showPage(id){

const page=pages[id]

const content=document.getElementById("content")

let html=""

html+=typeof page.text==="function"?page.text():page.text

page.options.forEach(o=>{
html+=`<button onclick="choose('${o.next}',${o.points||0})">${o.label}</button>`
})

content.innerHTML=html
}



function choose(next,points){

score+=points

showPage(next)

}



