body{
font-family: Arial, Helvetica, sans-serif;
background:#111;
color:white;
max-width:800px;
margin:auto;
padding:40px;
line-height:1.6;
}

button{
display:block;
margin:12px 0;
padding:12px 20px;
font-size:16px;
cursor:pointer;
background:#333;
color:white;
border:none;
}

button:hover{
background:#555;
}

img{
max-width:100%;
margin-top:20px;
}
